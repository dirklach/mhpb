{
  "titles": [
    { "id": 1, "text": "Mach einen 15-Minuten-Spaziergang." },
    { "id": 2, "text": "Tu dir selbst etwas gutes." },
    { "id": 3, "text": "Mache einen Spaziergang." },
    { "id": 4, "text": "Nimm dir eine Auszeit." },
    { "id": 5, "text": "Atme kontrolliert." },
    { "id": 6, "text": "Vergleiche dich nicht mit anderen." },
    { "id": 7, "text": "Sage deiner Familie, dass du sie lieb hast." },
    { "id": 8, "text": "Nimm dir den Raum, der dir zusteht." },
    { "id": 9, "text": "Achte auf dein inneres Gleichgewicht." },
    { "id": 10, "text": "Umarme deine Liebsten." },
    { "id": 11, "text": "Denke nicht, dass du jemanden zur Last fällst." },
    { "id": 12, "text": "Mach mehr von dem, was dir gut tut." },
    { "id": 13, "text": "Sei gut zu dir." },
    { "id": 14, "text": "Achte auf deine Gesundheit." },
    { "id": 15, "text": "Achte auf ausreichend Bewegung." },
    { "id": 16, "text": "Mache regelmäßig Sport." },
    { "id": 17, "text": "Achte auf deine Ernährung." },
    { "id": 18, "text": "Achte auf deine Erholung." },
    { "id": 19, "text": "Achte auf deinen Schlaf." },
    { "id": 20, "text": "Mach dich nicht unsichtbar." },
    { "id": 21, "text": "Schreib drei Dinge auf, für die du dankbar bist." },
    { "id": 22, "text": "Sprich über das, was dich beschäftigt." },
    { "id": 23, "text": "Setze klare Grenzen." },
    { "id": 24, "text": "Sag Nein." },
    { "id": 25, "text": "Verbringe Zeit in der Natur." },
    { "id": 26, "text": "Nimm dir eine Auszeit von dem, was dich stresst." },
    { "id": 27, "text": "Schreibe deine Gedanken auf." },
    { "id": 28, "text": "Höre Musik, die dir gut tut." },
    { "id": 29, "text": "Geh einem Hobby nach, das dich erfüllt." },
    { "id": 30, "text": "Akzeptiere, was du nicht ändern kannst." },
    { "id": 31, "text": "Gönne dir bewusst Ruhe ohne schlechtes Gewissen." },
    { "id": 32, "text": "Umgib dich mit Menschen, die dir gut tun." },
    { "id": 33, "text": "Bitte um Hilfe, wenn du sie brauchst." },
    { "id": 34, "text": "Schreibe auf, was dich glücklich macht und was dich belastet." },
    { "id": 35, "text": "Erinnere dich an Dinge, die du schon geschafft hast." },
    { "id": 36, "text": "Sei freundlich und sorgsam zu dir." },
    { "id": 37, "text": "Glaub nicht alles, was du denkst." },
    { "id": 38, "text": "Lebe im Moment." },
    { "id": 39, "text": "Schätze, was du hast." },
    { "id": 40, "text": "Mache anderen eine Freude." },
    { "id": 41, "text": "Ruhe dich aus." },
    { "id": 42, "text": "Denke an schöne Erinnerungen." },
    { "id": 43, "text": "Ich muss keine Konflikte lösen." },
    { "id": 44, "text": "Ich bin gut, so wie ich bin." },
    { "id": 45, "text": "Guck, was du geschafft hast." },
    { "id": 46, "text": "Ich darf stören." },
    { "id": 47, "text": "Ich bin nicht zu dünn, zu dick, zu irgendwas." },
    { "id": 48, "text": "Ich kann stolz auf mich sein." },
    { "id": 49, "text": "Ich bin genug." },
    { "id": 50, "text": "Ich bin nie fertig." }
  ]
}
